# ==============================================================================
# OWASP ATTACKFORGE - DOCKER ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and configure as needed.
# ==============================================================================

# Custom domain name for the lab
DOMAIN=hackthacker.lab

# SSL Organization Name
SSL_ORG=OWASP AttackForge

# MariaDB / MySQL Configuration
# (Used across mutillidae, dvwa, bwapp, xvwa, and vwa)
DB_USER=hackthacker
DB_PASS=hackthacker
MARIADB_ROOT_PASSWORD=hackthacker

# Apache Tomcat manager access credentials
# (Defaults to DB_USER / DB_PASS if left empty)
TOMCAT_USER=hackthacker
TOMCAT_PASS=hackthacker
