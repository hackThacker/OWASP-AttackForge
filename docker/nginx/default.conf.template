# ==============================================================================
# Nginx Router VHost Configuration Template
# (Environment variables like ${DOMAIN} will be substituted at container boot)
# ==============================================================================

# DNS Resolver for dynamic upstream hostname resolution (prevents boot crash if backends are down)
resolver 127.0.0.11 valid=10s ipv6=off;

# Global HTTP redirect to HTTPS
server {
    listen 8080;
    server_name mutillidae.${DOMAIN} dvwa.${DOMAIN} bwapp.${DOMAIN} xvwa.${DOMAIN} vwa.${DOMAIN} juiceshop.${DOMAIN} webgoat.${DOMAIN} webwolf.${DOMAIN} tomcat.${DOMAIN} wrongsecrets.${DOMAIN} securityshepherd.${DOMAIN} vulnerableapp.${DOMAIN} vulnerableapp-facade.${DOMAIN} crapi.${DOMAIN} crapi-mailhog.${DOMAIN} brokencrystals.${DOMAIN} brokencrystals-mailcatcher.${DOMAIN} dvws.${DOMAIN} zerohealth.${DOMAIN} zerohealth-api.${DOMAIN} restaurant.${DOMAIN};
    
    # Redirect all HTTP requests to HTTPS (running on mapped port 443 on the host)
    return 301 https://$host$request_uri;
}

# 1. Mutillidae II
server {
    listen 8443 ssl;
    server_name mutillidae.${DOMAIN};

    ssl_certificate /etc/nginx/ssl/owasp.crt;
    ssl_certificate_key /etc/nginx/ssl/owasp.key;

    location / {
        set $upstream_mutillidae mutillidae;
        proxy_pass http://$upstream_mutillidae:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

